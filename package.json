{
  "name": "gooey-pi",
  "version": "0.1.0",
  "description": "Electron desktop app for Pi/Codex-style coding sessions.",
  "author": "Jon DeHeus",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.1.2",
  "main": "./out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "pack": "PNPM_CONFIG_STORE_DIR=${PNPM_CONFIG_STORE_DIR:-$HOME/Library/pnpm/store/v11} PATH=$PWD/scripts/release/bin:$PATH electron-vite build && PNPM_CONFIG_STORE_DIR=${PNPM_CONFIG_STORE_DIR:-$HOME/Library/pnpm/store/v11} PATH=$PWD/scripts/release/bin:$PATH electron-builder --mac --dir --config electron-builder.yml",
    "dist:mac": "PNPM_CONFIG_STORE_DIR=${PNPM_CONFIG_STORE_DIR:-$HOME/Library/pnpm/store/v11} PATH=$PWD/scripts/release/bin:$PATH electron-vite build && PNPM_CONFIG_STORE_DIR=${PNPM_CONFIG_STORE_DIR:-$HOME/Library/pnpm/store/v11} PATH=$PWD/scripts/release/bin:$PATH electron-builder --mac --config electron-builder.yml",
    "standalone:verify": "node scripts/release/verify-standalone.mjs",
    "typecheck": "tsc --noEmit -p tsconfig.node.json && tsc --noEmit -p tsconfig.web.json",
    "test": "vitest run",
    "design-system:validate-storybook": "node scripts/design-system/validate-coss-storybook.mjs",
    "storybook": "storybook dev -p 6006",
    "storybook:build": "storybook build"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "0.91.1",
    "@aws-sdk/client-bedrock-runtime": "3.1046.0",
    "@base-ui/react": "^1.4.1",
    "@borewit/text-codec": "0.2.2",
    "@earendil-works/pi-coding-agent": "0.74.0",
    "@fontsource-variable/geist-mono": "^5.2.7",
    "@fontsource-variable/inter": "^5.2.8",
    "@google/genai": "1.52.0",
    "@mistralai/mistralai": "2.2.1",
    "@tokenizer/inflate": "0.4.1",
    "@tokenizer/token": "0.3.0",
    "balanced-match": "4.0.4",
    "brace-expansion": "5.0.6",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "emoji-regex": "8.0.0",
    "file-type": "21.3.4",
    "highlight.js": "^11.11.1",
    "ieee754": "1.2.1",
    "is-fullwidth-code-point": "3.0.0",
    "lucide-react": "^1.16.0",
    "ms": "2.1.3",
    "openai": "6.26.0",
    "partial-json": "0.1.7",
    "proxy-agent": "6.5.0",
    "react": "19.2.6",
    "react-day-picker": "^10.0.0",
    "react-dom": "19.2.6",
    "scheduler": "0.27.0",
    "strtok3": "10.3.5",
    "tailwind-merge": "^3.6.0",
    "token-types": "6.1.2",
    "uint8array-extras": "1.5.0",
    "wrappy": "1.0.2",
    "zod-to-json-schema": "3.25.2"
  },
  "devDependencies": {
    "@storybook/react-vite": "10.4.0",
    "@tailwindcss/vite": "^4.3.0",
    "@types/node": "25.8.0",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.1",
    "electron": "42.0.1",
    "electron-builder": "^26.8.1",
    "electron-vite": "5.0.0",
    "storybook": "10.4.0",
    "tailwindcss": "^4.3.0",
    "tw-animate-css": "^1.4.0",
    "typescript": "6.0.3",
    "vite": "8.0.13",
    "vitest": "4.1.6"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@google/genai",
      "electron",
      "esbuild",
      "koffi",
      "protobufjs"
    ]
  }
}
